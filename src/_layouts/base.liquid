<!doctype html>
<html lang="{{ meta.lang }}" class="spectrum spectrum--medium spectrum--light">
  <head>
    {% include "head/meta"
      title:title,
      description:description,
      meta:meta
    %}
   
    {% if config.typeKitId %}
      <link rel="preconnect" href="https://use.typekit.net" />
      <link rel="dns-prefetch" href="https://use.typekit.net" />
      <link rel="stylesheet" href="https://use.typekit.net/{{ config.typeKitId }}.css" />
    {% endif %}
   
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body class="page--{% if page.fileSlug %}{{ page.fileSlug }}{% else %}home{% endif %} layout--{{ layout | removeExtension }} spectrum spectrum--light spectrum-Body spectrum-Body--sizeM">
    {% include "nav" %}
    {{ content }}
    {% include "footer" %}
    {% spriteSheet %}
  </body>
</html>
