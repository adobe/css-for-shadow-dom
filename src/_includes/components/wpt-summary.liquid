{%- assign browserVersions = wptBrowsers | default: feature.data.wptBrowsers -%}
{%- assign wptSummary = wptResults.summary | default: feature.data.wptResults.summary -%}

<div class="wpt-summary flex-row">
    <div class="wpt-summary_header">
        <h3 class="spectrum-Body spectrum-Body--sizeS spectrum-Body-strong">Web Platform Tests <span class="visually-hidden">for {{ feature.data.title }}</span></h3>
        
        {% unless featureTemplate %}
            <a href="{{ feature.url }}" class="spectrum-Body spectrum-Body--sizeXS">View all tests <span class="visually-hidden">for {{ feature.data.title }}</span></a>
        {% endunless %}
    </div>

    {%- for browser in wptSummary-%}
        {%- assign browserName = browser[0] -%}
        {%- assign browserResult = browser[1] -%}
        {%- assign browserIcon = "browser-mono-" | append: browserName -%}
        {%- assign browserVersion = browserVersions[browserName] -%}
        {%- assign browserLabel = browserName | titleCase -%}
    
        {% testResult browserResult %}
            <span class="wpt-summary_tag flex-row">
                {% icon browserIcon %}
                <span>
                    {{ browserLabel }} {{ browserVersion }}: {{ browserResult | titleCase }}
                </span>
            </span>
        {% endtestResult %}
    {%- endfor -%}
</div>