{% endcomment %}
{% assign label = issue.label | default: feature.data.issue.label %}
{% assign description = issue.description | default: feature.data.issue.description %}
{% assign status = issue.status | default: feature.data.issue.status %}
{% assign links = issue.links | default: feature.data.issue.links %}

<div class="issue-card spectrum-Body spectrum-Body--sizeS">

    <h4 class="spectrum-Body spectrum-Body--sizeS spectrum-Body-medium">{{ label }}</h4>
    <p>{{ description }}</p>

    <strong class="issue-card__status {{ status }} spectrum-Body-medium">{{ status | titleCase }}</strong>

    <div class="issue-card__links">
        {% for link in links %}
            {%- assign wgID = link.url | issueID -%}

            {% if link.browser %}
                {% assign ariaLabel = " issue" | prepend: link.browser | titleCase | default: "" %}
            {% else %}
                {%- assign ariaLabel = "CSSWG issue " | append: wgID -%}
            {% endif %}

            <a href="{{ link.url }}" aria-label="{{ ariaLabel }}">
            {%- if link.browser -%}
                {%- assign browser = link.browser | prepend: "browser-mono-" -%}
                {%- icon browser -%}
            {%- else -%}
                #{{ wgID }}
            {%- endif -%}
            </a>
        {% endfor %}
    </div>
</div>