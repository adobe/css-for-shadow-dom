{%- assign pageTitle = meta.siteName -%}
{%- assign pageDescription = meta.siteDescription -%}
{%- assign pageCanonicalUrl = page.url | htmlBaseUrl: meta.origin -%}
{%- assign defaultOpenGraphImage = '/assets/images/open-graph-image.jpg' | htmlBaseUrl: meta.origin -%}
{%- assign feedUrl = '/feed.xml' | htmlBaseUrl: meta.origin -%}

{%- if title -%}
  {% if page.url != '/' %}
    {%- assign pageTitle = title | append: ' | ' | append: meta.siteName -%}
  {% else %}
    {% assign pageTitle = title %}
  {% endif %}
{%- endif -%}

{%- if description -%}
  {%- assign pageDescription = description -%}
{%- endif -%}

<meta charset='UTF-8'>
<meta name='viewport' content='width=device-width, initial-scale=1.0'>
<title>{{ pageTitle }}</title>
<meta name='description' content='{{ pageDescription }}'>
<meta name='theme-color' content='{{ meta.themeColor }}'>
<meta name='generator' content='{{ eleventy.generator }}'>
<meta name='color-scheme' content='light'>
<meta name='view-transition' content='same-origin'>
<link rel='canonical' href='{{ pageCanonicalUrl }}'>

<meta property='og:url' content='{{ pageCanonicalUrl }}'>
<meta property='og:type' content='website'>
<meta property='og:title' content='{{ pageTitle }}'>
<meta property='og:image' content='{{ defaultOpenGraphImage }}'>
<meta property='og:image:alt' content='{{ meta.siteName }}'>
<meta property='og:image:width' content='1200'>
<meta property='og:image:height' content='630'>
<meta property='og:description' content='{{ pageDescription }}'>
<meta property='og:site_name' content='{{ meta.siteName }}'>
<meta property='og:locale' content='{{ meta.locale }}'>

{% comment %} <link href="{{ feedUrl }}" rel="alternate" title="{{ meta.siteName }} RSS feed"> {% endcomment %}

<link rel='icon' href='/assets/images/favicon.ico' sizes='any'>
<link rel='icon' href='/assets/images/favicon.svg' type='image/svg+xml'>
<link rel='apple-touch-icon' sizes='180x180' href='/assets/images/apple-touch-icon.png'>
