{% endcomment %}

{% for entry in changelog.data %}
  {% assign firstChangeType = entry.changes[0].type %}
  <article class='changelog-entry'>
    <div class='flex-row'>
      <h2>
        <em>{{ entry.date | formatDate: 'MMMM D, YYYY' }}</em>
      </h2>

      {% if firstChangeType != 'feature-added' %}
        {% severity entry.severity %}
      {% endif %}
    </div>

    <div class='flow-content'>
      {% if firstChangeType == 'feature-added' %}
        <p>{{ entry.summary }}</p>
      {% else %}
        <h3>{{ entry.summary }}</h3>

        <ul>
          {% for change in entry.changes %}
            <li>
              <strong>{{ change.type | changelogEntryTitle }}:</strong>

              {% if change.test %}
                {% if change.type == 'test-result' %}
                  Test "<em>{{ change.test }}</em>" now {{ change.after | testStatus }} in
                  {{ change.browser | titleCase }}
                {% else %}
                  <em>{{ change.test }}</em>
                {% endif %}
              {% endif %}

              {% if change.type == 'baseline' %}
                availability has {% severityStatus change.before change.after %} to "{{ change.after | titleCase }}"
              {% endif %}

              {% if change.milestone == 'baseline-widely-available' %}
                🎉 Feature is now Baseline widely available!
              {% endif %}

              {% if change.milestone == 'all-browsers-passing' %}
                🎉 All browsers now pass WPT!
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </article>
{% endfor %}
